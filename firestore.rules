rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - username: string (required, unique)
    //   - displayName: string (required)
    //   - photoURL: string (optional)
    //   - preferences: map (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (optional)
    //
    // Collection: usernames
    // Document ID: {username}
    // Fields:
    //   - uid: string (required)
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['username', 'displayName', 'createdAt']) &&
             data.username is string && data.username.size() >= 3 && data.username.size() <= 20 &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() <= 50 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000)) &&
             (!('preferences' in data) || data.preferences is map);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && 
                    request.resource.data.username == resource.data.username; // Username immutable
      allow delete: if false; // Profiles shouldn't be deleted easily
    }

    match /usernames/{username} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.uid == request.auth.uid &&
                    username is string && username.size() >= 3 && username.size() <= 20;
      allow delete: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }
  }
}
